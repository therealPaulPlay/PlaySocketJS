{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "strictNullChecks": false, // Disable "X is possibly null", many assumptions made are safe or would result in property access via "." throwing and getting caught
        "useUnknownInCatchVariables": false,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM"],
        "types": ["node"],
        "skipLibCheck": true
    },
    "include": ["src"]
}
